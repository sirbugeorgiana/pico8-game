pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
  p_x = 60
  p_y = 100
  viteza_pisica = 1
  timer_animatie = 0
  
  pisica_gura_inchisa = 1
  pisica_gura_deschisa = 2
  pisica_sprite_curent = 1
end

function _update()
  timer_animatie += 1
  
  if timer_animatie % 30 < 15 then
    pisica_sprite_curent = pisica_gura_inchisa
  else
    pisica_sprite_curent = pisica_gura_deschisa
  end
  
  -- miscare automata in sus
  -- verificam daca deasupra pisicii (p_y - 1) este perete
  if not fget(mget(p_x/8, (p_y-1)/8), 0) and
     not fget(mget((p_x+7)/8, (p_y-1)/8), 0) then
    p_y -= viteza_pisica
  end
  
  if btn(0) then
    if not fget(mget((p_x-1)/8, p_y/8), 0) and
       not fget(mget((p_x-1)/8, (p_y+7)/8), 0) then
      p_x -= 1.5
    end
  end
  
  if btn(1) then
    if not fget(mget((p_x+8)/8, p_y/8), 0) and
       not fget(mget((p_x+8)/8, (p_y+7)/8), 0) then
      p_x += 1.5
    end
  end
end

function _draw()
  cls()
  map(0,0,0,0,16,16)
  spr(pisica_sprite_curent, p_x, p_y)
end
